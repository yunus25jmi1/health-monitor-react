/* Cloudflare Pages redirect rules for React Router */

/* Redirect all routes to index.html (SPA routing) */
/*    /index.html  200

/* Specific asset caching */
/assets/*  Cache-Control: public, max-age=31536000, immutable
/favicon.svg  Cache-Control: public, max-age=3600

/* API routes - no caching */
/api/*  Cache-Control: no-cache
